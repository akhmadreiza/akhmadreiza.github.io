---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  heroImage?: string;
  readingTime?: string;
}

const { title, description, pubDate, updatedDate, tags = [], heroImage, readingTime } = Astro.props;

const pageURL = new URL(Astro.url.pathname, Astro.site).href;
const twitterShareURL = `https://twitter.com/intent/tweet?url=${encodeURIComponent(pageURL)}&text=${encodeURIComponent(title)}`;
const linkedinShareURL = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageURL)}`;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={title} description={description} ogImage={heroImage}>
  <article>
    {heroImage && (
      <img
        src={heroImage}
        alt={title}
        class="w-full rounded-lg object-cover max-h-72 mb-8"
      />
    )}
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-3">{title}</h1>
      <p class="text-gray-600 dark:text-gray-400 text-base mb-4">{description}</p>
      <div class="flex flex-wrap items-center gap-3 text-sm text-gray-400 dark:text-gray-500">
        <time>{formattedPubDate}</time>
        {readingTime && <span>· {readingTime}</span>}
        {formattedUpdatedDate && (
          <span>· Updated {formattedUpdatedDate}</span>
        )}
      </div>
      {tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a
              href={`/blog/tag/${tag}`}
              class="text-xs bg-gray-100 dark:bg-gray-700 hover:bg-blue-100 dark:hover:bg-blue-900/40 hover:text-blue-700 dark:hover:text-blue-400 text-gray-600 dark:text-gray-300 px-2 py-0.5 rounded transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>
    <div class="prose">
      <slot />
    </div>

    <div class="mt-12 pt-6 border-t border-gray-200 dark:border-gray-700">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">Share this post</p>
      <div class="flex items-center gap-3">
        <a
          href={twitterShareURL}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Share on X"
          class="p-2 rounded-md bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.741l7.73-8.835L1.254 2.25H8.08l4.213 5.567 5.95-5.567zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a
          href={linkedinShareURL}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Share on LinkedIn"
          class="p-2 rounded-md bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <button
          id="copy-link"
          data-url={pageURL}
          aria-label="Copy link"
          class="p-2 rounded-md bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
        >
          <svg id="copy-icon" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
          </svg>
          <svg id="check-icon" class="w-4 h-4 hidden text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </button>
      </div>
    </div>
  </article>
</Base>

<script>
  const btn = document.getElementById('copy-link');
  btn?.addEventListener('click', () => {
    const url = btn.getAttribute('data-url') ?? window.location.href;
    navigator.clipboard.writeText(url).then(() => {
      document.getElementById('copy-icon')?.classList.add('hidden');
      document.getElementById('check-icon')?.classList.remove('hidden');
      setTimeout(() => {
        document.getElementById('copy-icon')?.classList.remove('hidden');
        document.getElementById('check-icon')?.classList.add('hidden');
      }, 2000);
    });
  });
</script>
