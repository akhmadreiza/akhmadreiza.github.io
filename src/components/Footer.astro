    <span>&copy; {year} Reiza. All rights reserved.</span>
    <div class="flex gap-4">
      <a href="/rss.xml" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">RSS</a>
      <a href="https://github.com/akhmadreiza" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">GitHub</a>
    </div>
  </div>
</footer>
