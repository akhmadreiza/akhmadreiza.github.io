---
import BlogPost from '../../layouts/BlogPost.astro';
import { getCollection, render } from 'astro:content';
import { readingTime } from '../../utils/readingTime';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return sorted.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      prevPost: index < sorted.length - 1 ? { id: sorted[index + 1].id, title: sorted[index + 1].data.title } : undefined,
      nextPost: index > 0 ? { id: sorted[index - 1].id, title: sorted[index - 1].data.title } : undefined,
    },
  }));
};

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, tags, heroImage } = post.data;
const timeToRead = readingTime(post.body ?? '');
---

<BlogPost
  title={title}
  description={description}
  pubDate={pubDate}
  updatedDate={updatedDate}
  tags={tags}
  heroImage={heroImage}
  readingTime={timeToRead}
  prevPost={prevPost}
  nextPost={nextPost}
>
  <Content />
</BlogPost>
