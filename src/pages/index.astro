---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import profileImg from '../assets/profile.jpg';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const featuredProjects = await getCollection('projects', ({ data }) => data.featured);
featuredProjects.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base title="Akhmad Reiza — Home" description="Personal website of Akhmad Reiza, a software engineer writing about distributed systems, code, and ideas.">
  <section class="mb-16 flex flex-col sm:flex-row items-center gap-8">
    <div class="flex-1">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">Hi, I'm Akhmad Reiza Armando.</h1>
      <p class="text-xl text-gray-600 dark:text-gray-400 leading-relaxed">
        Software engineer, husband, and dad based in Indonesia. I care about well-designed systems,
        finding the best bowl of food in any city I visit, and being present for the people I love.
        This site is where I write about whatever's on my mind.
      </p>
    </div>
    <div class="shrink-0 order-first sm:order-last">
      <Image
        src={profileImg}
        alt="Reiza's profile picture"
        width={128}
        height={128}
        class="w-32 h-32 rounded-full object-cover ring-2 ring-gray-200 dark:ring-gray-700"
      />
    </div>
  </section>

  {recentPosts.length > 0 && (
    <section class="mb-16">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white">Recent Posts</h2>
        <a href="/blog" class="text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium transition-colors">
          All posts &rarr;
        </a>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {recentPosts.map((post) => <PostCard post={post} compact />)}
      </div>
    </section>
  )}

  {featuredProjects.length > 0 && (
    <section>
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white">Featured Projects</h2>
        <a href="/projects" class="text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium transition-colors">
          All projects &rarr;
        </a>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>
  )}
</Base>
